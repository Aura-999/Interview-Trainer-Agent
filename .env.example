# -- IBM watsonx.ai ------------------------------------------
WATSONX_API_KEY=your_watsonx_api_key_here
WATSONX_PROJECT_ID=your_watsonx_project_id_here
WATSONX_URL=https://eu-gb.ml.cloud.ibm.com

# LLM model — use a model supported by your region
GRANITE_MODEL_ID=meta-llama/llama-3-3-70b-instruct

# -- IBM Cloud Object Storage ---------------------------------
COS_API_KEY=your_cos_api_key_here
COS_INSTANCE_ID=your_cos_instance_id_here
COS_ENDPOINT=https://s3.eu-gb.cloud-object-storage.appdomain.cloud
COS_BUCKET=interview-kb

# -- App settings ---------------------------------------------
CHROMA_DB_PATH=./chroma_db
CACHE_DIR=./cache
# Max tokens Granite may emit per call — keep low to conserve Lite quota
MAX_NEW_TOKENS_QUESTIONS=400
MAX_NEW_TOKENS_ANSWER=300
MAX_NEW_TOKENS_FEEDBACK=280
# Number of KB chunks to retrieve per query
RAG_TOP_K=5
